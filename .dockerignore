# Ignore git and local VCS folders
.git
.github
.gitignore

# Ignore Claude/Gemini and IDE metadata
.claude
.gemini
.idea
.vscode

# Ignore environment file (sensitive keys)
.env

# Ignore client dependencies and local builds
node_modules/
package-lock.json

# Ignore native mobile application builds
android/
capacitor.config.json

# Ignore backup or temporary files
*.log
*.tmp
.DS_Store
