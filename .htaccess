# Block access to .env files
<Files ".env">
    Require all denied
</Files>

# =========================================================================
# DOMAIN REDIRECTION - Redirect alwaysdata.net to byahero.app for web/PC browsers
# =========================================================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_HOST} ^(www\.)?byahero\.alwaysdata\.net$ [NC]
    # Only redirect standard browser requests expecting HTML (web/PC users)
    RewriteCond %{HTTP:Accept} text/html [NC]
    # Do not redirect core API endpoints to avoid breaking Capacitor apps
    RewriteCond %{REQUEST_URI} !/(api\.php|auth_api\.php|update_geo_location\.php|map_data\.php|stream_buses\.php|api_pins\.php|login.php)$ [NC]
    RewriteRule ^(.*)$ https://byahero.app/$1 [R=301,L]
</IfModule>


# =========================================================================
# GZIP COMPRESSION - Reduces transfer size by ~70% for text-based assets
# =========================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/ld+json
    AddOutputFilterByType DEFLATE application/xml application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2 font/woff font/ttf application/font-woff application/font-woff2
</IfModule>

# =========================================================================
# BROWSER CACHING - Tells browsers to cache static assets locally
# Dramatically speeds up repeat visits and page navigations
# =========================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images: cache for 30 days
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    
    # CSS & JS: cache for 7 days (use ?v=X query strings to bust cache)
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    
    # Fonts: cache for 30 days
    ExpiresByType font/woff "access plus 30 days"
    ExpiresByType font/woff2 "access plus 30 days"
    ExpiresByType application/font-woff "access plus 30 days"
    ExpiresByType application/font-woff2 "access plus 30 days"
    ExpiresByType font/ttf "access plus 30 days"
    
    # HTML/PHP: no caching (always fresh)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Fallback cache headers if mod_expires not available
<IfModule mod_headers.c>
    # CSS and JS files
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800, immutable"
    </FilesMatch>
    
    # Images
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    
    # Fonts
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    
    # Prevent caching of PHP pages
    <FilesMatch "\.php$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    
    # Security: Prevent MIME sniffing
    Header set X-Content-Type-Options "nosniff"
</IfModule>